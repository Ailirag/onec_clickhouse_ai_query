# Порт HTTP-сервера приложения (по умолчанию 3000).
PORT=3000

# GEMINI_API_KEY — ключ Google Gemini. Нужен только если выбран провайдер Gemini.
# Для провайдера YandexGPT не требуется (ключ и Folder ID задаются в интерфейсе администратором).
GEMINI_API_KEY=""

# NODE_ENV=production для запуска собранной версии (npm run start).
# NODE_ENV="production"

# Максимум строк, возвращаемых одним ad-hoc запросом в интерфейс (защита от
# гигантских выборок на таблицах в миллиарды строк). По умолчанию 5000.
# MAX_RESULT_ROWS=5000

# Таймаут одного HTTP-запроса к ClickHouse в миллисекундах. По умолчанию 60000.
# CLICKHOUSE_TIMEOUT_MS=60000
